{
  "name": "mouse-ramrod-web",
  "version": "1.0.5",
  "private": true,
  "description": "Deadly game of mouse and ramrod",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "start": "webpack serve --config webpack_configs/webpack.config.js --mode development --color",
    "android": "webpack --config webpack_configs/android.webpack.config.js --mode production",
    "build": "webpack --config webpack_configs/production.webpack.config.js --mode production",
    "style": "npx eslint . -c linters/eslint.config.js",
    "style:fix": "npx eslint . -c linters/eslint.config.js --fix",
    "style2": "npx stylelint --config linters/stylelint.config.js \"src/**/*.css\"",
    "style2:fix": "npx stylelint --config linters/stylelint.config.js \"src/**/*.css\" --fix",
    "test": "node --test --test-reporter dot",
    "test:verbose": "node --test",
    "test:watch": "node --test --watch ./tests",
    "updates": "npx ncu",
    "updates:fix": "npx ncu -u && npm install && npm audit fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asavan/mouse-ramrod.git"
  },
  "homepage": "https://asavan.github.io/mouse-ramrod/",
  "dependencies": {
    "netutils": "github:asavan/netutils#5b0d666f6772a5d6a7bd41cf56f3706253fee03b"
  },
  "devDependencies": {
    "devdeps": "github:asavan/dev-deps#v0.0.15"
  }
}
